# App
SECRET_KEY=change-this-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080
PASSWORD_RESET_EXPIRE_MINUTES=60

# Database
# Inside Docker: DATABASE_URL=postgresql://user:password@postgres:5432/chc
# Outside Docker (local dev): port 5433 to avoid conflict with local PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5433/chc

# Redis
# Inside Docker: redis://redis:6379/X
# Outside Docker: redis://localhost:6379/X
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# AWS S3 (LocalStack for dev)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET_NAME=chc-files

# SMTP (MailHog for dev)
# Inside Docker: SMTP_HOST=mailhog
# Outside Docker: SMTP_HOST=localhost
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@chc.com

# AWS SES (optional — leave empty to use SMTP above)
SES_SENDER_EMAIL=

# AI API — Report Service (Excel Analysis)
# Prod: AI_API_URL=https://api.chc-consulting.sotatek.works
AI_API_URL=
AI_API_USERNAME=
AI_API_PASSWORD=

# Webhook callback — Report Service → CHC Backend khi AI task xong
# Set BACKEND_BASE_URL = public URL của CHC Backend (vd: https://chc-backend.domain.com)
# Report Service sẽ POST kết quả về {BACKEND_BASE_URL}/requests/webhook/ai-result
# WEBHOOK_SECRET phải giống nhau ở cả 2 bên (CHC Backend + Report Service .env)
# Nếu không set → fallback poll mode (worker poll 5s/lần, tối đa 10 phút)
BACKEND_BASE_URL=
WEBHOOK_SECRET=

# Domain config
# Dev: set both to "localhost"
# Prod: ADMIN_DOMAIN=admin.chc.com, BASE_DOMAIN=chc.com
ADMIN_DOMAIN=localhost
BASE_DOMAIN=localhost

# Security
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
MAX_UPLOAD_SIZE_MB=50
